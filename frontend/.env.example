# Browser requests stay same-origin through the Next.js /api rewrite.
NEXT_PUBLIC_API_URL=/api

# Backend origin only — no trailing slash and no /api suffix.
BACKEND_URL=https://api.example.com

# Stable production origins.
NEXT_PUBLIC_SITE_URL=https://www.example.com
# Stable public R2 media origin. It is embedded at build time for Next Image allowlisting;
# it must match the backend R2_PUBLIC_URL and does not configure R2 Bucket CORS.
NEXT_PUBLIC_MEDIA_ORIGIN=https://media.example.com

# Server-only value shared with the backend revalidation callback.
REVALIDATE_SECRET=replace-with-a-long-random-secret
