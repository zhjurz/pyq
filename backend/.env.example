# ===== 运行环境 =====
NODE_ENV=production
PORT=4000

# ===== MySQL 数据库 =====
# 手动部署: 127.0.0.1
# Docker Compose: mysql (对应 docker-compose.yml 中的 service 名)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=kanle
DB_PASSWORD=change-me
DB_NAME=moment_blog

# ===== JWT 认证 =====
# 生产环境务必改为随机长字符串（建议 32+ 字符）
JWT_SECRET=please-generate-a-long-random-string
JWT_EXPIRES_IN=7d

# ===== 初始管理员（仅首次 seed 创建时生效）=====
# 注意：管理员创建后，修改 ADMIN_PASSWORD 不会更新已有账号
# 重置密码请运行: node dist/scripts/reset-password.js
ADMIN_EMAIL=admin@kanle.net
ADMIN_PASSWORD=123456
ADMIN_USERNAME=admin

# ===== 前端地址（用于 CORS 跨域 + 按需 revalidate 回调）=====
# 生产环境填你的真实域名，如 https://yourdomain.com
CLIENT_URL=http://localhost:3000

# ===== 按需重验证密钥 =====
# 须与前端 REVALIDATE_SECRET / NEXT_PUBLIC_REVALIDATE_SECRET 保持一致
# 作用：发动态/评论后触发前端页面即时刷新
REVALIDATE_SECRET=kanle-revalidate

# ===== 定时豆瓣同步 =====
# Vercel Cron / 外部调度器请求 /api/douban/cron-sync 的 Bearer 密钥
CRON_SECRET=please-generate-a-long-random-cron-secret

# ===== Vercel Serverless 部署专用 =====
# 部署到 Vercel 时会自动注入 VERCEL=1，代码用它判断当前是否运行在
# Serverless 环境（调小数据库连接池、禁用本地磁盘存储等），一般不需要手动设置。
# VERCEL=1

# 数据库连接池（不填则按是否 Serverless 自动取默认值：Serverless 2 / 传统部署 10）
# DB_POOL_MAX=2
# DB_POOL_IDLE=5000

# 大多数托管 MySQL（PlanetScale / TiDB Serverless / 阿里云 RDS 外网连接等）要求 TLS
# DB_SSL=true
# DB_SSL_REJECT_UNAUTHORIZED=true

# ===== Cloudflare R2 对象存储（唯一支持的持久媒体存储）=====
# 媒体文件（图片/音频/视频/动态照片）需要配置 R2；Vercel Serverless
# 文件系统只读且不持久。创建 Object Read & Write API Token 后填入以下变量。
# 浏览器直传还必须在 R2 Bucket 设置中配置 CORS，详见 VERCEL_DEPLOYMENT.md。
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
# Bucket 绑定的公开访问域名（R2 Bucket 设置里绑定自定义域名，或使用
# 开发用的 r2.dev 公开域名），不带末尾斜杠
R2_PUBLIC_URL=https://media.yourdomain.com
